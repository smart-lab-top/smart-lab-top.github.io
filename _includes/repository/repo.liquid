<div class="repo p-2 text-center">
  <a href="https://github.com/{{ include.repository }}" style="text-decoration: none; color: inherit;">
    <div style="border: 1px solid #e0e0e0; border-radius: 6px; padding: 16px; background-color: #f6f8fa; min-height: 120px; display: flex; flex-direction: column; justify-content: space-between;">
      <div>
        <h3 style="margin: 0 0 8px 0; font-size: 16px;">
          <span style="color: #0969da;">{{ include.repository }}</span>
        </h3>
        <p style="margin: 0; font-size: 12px; color: #656d76;">
          Repository from GitHub
        </p>
      </div>
      <div style="text-align: left; font-size: 12px; color: #656d76; margin-top: 8px;">
        <a href="https://github.com/{{ include.repository }}" target="_blank" style="color: #0969da; text-decoration: none;">
          View on GitHub →
        </a>
      </div>
    </div>
  </a>
</div>
